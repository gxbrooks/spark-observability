# Secrets Configuration Template
# 
# This file is a template for secrets.yaml. Copy this file to secrets.yaml and fill in
# the actual secret values. The secrets.yaml file is gitignored and should never be
# committed to version control.
#
# Usage:
#   1. Copy this file: cp vars/secrets.yaml.example vars/secrets.yaml
#   2. Edit vars/secrets.yaml with your actual secrets
#   3. Set appropriate file permissions: chmod 600 vars/secrets.yaml
#
# Environment Variable Override:
#   Secrets can also be provided via environment variables. If an environment variable
#   exists (e.g., ES_PASSWORD), it will take precedence over values in this file.
#
# Priority Order (highest to lowest):
#   1. Environment variables (e.g., export ES_PASSWORD="...")
#   2. secrets.yaml file
#   3. Default values in variables.yaml (for non-sensitive defaults only)

# Elasticsearch credentials
ES_PASSWORD: "MyElastic2026"
ES_USER: "elastic"  # Usually doesn't need to be secret, but can be overridden here

# Kibana credentials
KB_PASSWORD: "MyKibana2026"
KB_USER: "kibana_system"  # Usually doesn't need to be secret

# Grafana credentials
GF_SECURITY_ADMIN_PASSWORD: "myGrafana2026"
GF_SECURITY_ADMIN_USER: "admin"  # Usually doesn't need to be secret

# Elasticsearch encryption key (for Kibana)
EB_ENCRYPTION_KEY: "ThisismyKibanaEncryptionKeyFor2026"

# Note: For production environments, consider using:
# 
# Open Source Options (Standalone Linux):
# - HashiCorp Vault (recommended for production) - https://www.vaultproject.io/
#   * Full-featured secrets management with API, dynamic secrets, audit logging
#   * Can run standalone with file storage backend
#   * REST API for integration with generate_contexts.py
#
# - SOPS (Mozilla Secrets OPerationS) - https://github.com/getsops/sops
#   * Simple file-based encryption, git-friendly
#   * Encrypts YAML/JSON files directly
#   * Good for infrastructure-as-code workflows
#
# - Pass (Password Store) - https://www.passwordstore.org/
#   * Simple GPG-based password manager
#   * CLI-friendly, git-friendly
#   * Good for personal/small team use
#
# - Ansible Vault - https://docs.ansible.com/ansible/latest/vault_guide/
#   * Integrated with Ansible playbooks
#   * Encrypts YAML variables
#   * Good if you're heavily Ansible-based
#
# Cloud/Enterprise Options:
# - AWS Secrets Manager (AWS deployments)
# - Azure Key Vault (Azure deployments)
# - Kubernetes Secrets (K8s deployments)

