# JupyterHub Helm Chart Values
# Multi-user JupyterHub with NativeAuthenticator for Spark development

# Hub configuration
hub:
  image:
    name: quay.io/jupyterhub/k8s-hub
    tag: "3.0.0"
  
  # Database for user information using NFS
  db:
    type: sqlite-pvc
    pvc:
      storageClassName: "" # Manual binding to NFS PV
      storage: 1Gi
      # Will bind to manually created NFS PV
  
  # Hub service configuration
  service:
    type: ClusterIP  # Proxy handles external access
  
  # Resource limits for Hub pod
  resources:
    requests:
      cpu: 200m
      memory: 512Mi
    limits:
      cpu: 1
      memory: 1Gi
  
  # Hub configuration
  config:
    JupyterHub:
      admin_access: true
      # FirstUseAuthenticator: First user to login becomes admin
      # All subsequent users need admin approval
      authenticator_class: firstuseauthenticator.FirstUseAuthenticator
    
    FirstUseAuthenticator:
      # Admin users - these get admin privileges on first login
      admin_users:
        - admin
        - gxbrooks
      # Create users on first login (password set during first login)
      create_users: true

# Proxy configuration
proxy:
  service:
    type: NodePort
    nodePorts:
      https: 32443  # HTTPS port
  
  https:
    enabled: true
    type: secret
    secret:
      name: jupyterhub-tls  # Created by generate_jupyter_certs.yml
  
  chp:
    resources:
      requests:
        cpu: 200m
        memory: 512Mi
      limits:
        cpu: 1
        memory: 1Gi

# Single-user notebook server configuration
singleuser:
  # Use PySpark-enabled image
  image:
    name: jupyter/pyspark-notebook
    tag: latest
    pullPolicy: IfNotPresent
  
  # Resource limits per user
  cpu:
    limit: 2
    guarantee: 1
  memory:
    limit: 4G
    guarantee: 2G
  
  # Storage for user notebooks
  storage:
    type: dynamic
    capacity: 10Gi
    dynamic:
      storageClass: "" # Use default storage class
  
  # Extra environment variables for Spark
  extraEnv:
    JUPYTER_ENABLE_LAB: "yes"
    SPARK_MASTER: "spark://spark-master-0.spark-master-headless.spark.svc.cluster.local:7077"
    SPARK_HOME: "/usr/local/spark"
    PYSPARK_DRIVER_PYTHON: "jupyter"
    PYSPARK_DRIVER_PYTHON_OPTS: "lab"
  
  # Additional pod configuration
  profileList: []
  
  # Lifecycle hooks for mounting volumes
  lifecycleHooks:
    postStart:
      exec:
        command: ["/bin/sh", "-c", "echo 'User pod started'"]
  
  # Start container as jovyan user
  uid: 1000
  fsGid: 100
  
  # Network policy
  networkPolicy:
    enabled: false  # Disable for now, enable in production
  
  # Default URL for users
  defaultUrl: "/lab"

# Scheduling configuration
scheduling:
  userScheduler:
    enabled: true
    replicas: 1
  
  podPriority:
    enabled: false
  
  userPlaceholder:
    enabled: false
    replicas: 0

# Culling idle servers
cull:
  enabled: true
  timeout: 3600  # 1 hour
  every: 600     # Check every 10 minutes
  users: false   # Don't cull named servers
  adminUsers: false  # Don't cull admin users
  removeNamedServers: false
  maxAge: 0  # Don't cull based on age

# Image pre-pulling
prePuller:
  hook:
    enabled: true
  continuous:
    enabled: false

# Debugging
debug:
  enabled: false

