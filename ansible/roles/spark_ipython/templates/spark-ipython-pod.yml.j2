apiVersion: v1
kind: Pod
metadata:
  name: {{ pyspark_ipython_pod_name | default('pyspark-ipython') }}
  namespace: spark
spec:
  containers:
  - name: {{ pyspark_ipython_pod_name | default('pyspark-ipython') }}
    image: {{ spark_image }}:{{ spark_tag }}
    imagePullPolicy: Always
    command: ["/bin/bash"]
    args: ["-c", "sleep infinity"]
    envFrom:
    - configMapRef:
        name: spark-configmap
    env:
    - name: SPARK_MASTER
      value: spark://spark-master:7077
    resources:
      requests:
        cpu: "{{ pyspark_ipython_cpu_request | default('500m') }}"
        memory: "{{ pyspark_ipython_memory_request | default('1Gi') }}"
      limits:
        cpu: "{{ pyspark_ipython_cpu_limit | default('1') }}"
        memory: "{{ pyspark_ipython_memory_limit | default('2Gi') }}"
    volumeMounts:
    - name: spark-events
      mountPath: /mnt/spark-events
  volumes:
  - name: spark-events
    hostPath:
      path: /mnt/spark-events
      type: DirectoryOrCreate
  restartPolicy: Never
