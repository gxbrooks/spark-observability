apiVersion: apps/v1
kind: Deployment
metadata:
  name: spark-history
  namespace: spark
spec:
  replicas: 1
  selector:
    matchLabels:
      app: spark-history
  template:
    metadata:
      labels:
        app: spark-history
    spec:
      serviceAccountName: spark
      # Pin history server to Lab2 node
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
            - matchExpressions:
              - key: kubernetes.io/hostname
                operator: In
                values:
                - lab2
      # No init container needed - subPathExpr handles directory creation
      # Add DNS policy for consistency with other components
      dnsPolicy: ClusterFirst
      dnsConfig:
        options:
          - name: ndots
            value: "5"
      initContainers:
        - name: init-logs
          image: "{{ spark_image }}:{{ spark_tag }}"
          command: ["/bin/bash", "-c"]
          args:
            - |
              mkdir -p /mnt/spark/logs/$(POD_NAME)
              chown -R 185:185 /mnt/spark/logs/$(POD_NAME)
              chmod 755 /mnt/spark/logs/$(POD_NAME)
          env:
            - name: POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
          volumeMounts:
            - name: spark-logs-host
              mountPath: /mnt/spark/logs
          securityContext:
            runAsUser: 0
      containers:
        - name: spark-history
          image: "{{ spark_image }}:{{ spark_tag }}"
          imagePullPolicy: Always
          command: ["/bin/bash", "-c"]
          args: 
            - |
              export SPARK_HISTORY_OPTS="-XX:+UseG1GC -Xlog:gc*:file=/opt/spark/logs/gc-history.log:time,uptime,level,tags:filecount=10,filesize=10M"
              exec /opt/spark/sbin/start-history-server.sh
          envFrom:
            - configMapRef:
                name: spark-configmap
          env:
            - name: SPARK_LOCAL_IP
              valueFrom:
                fieldRef:
                  fieldPath: status.podIP
            # Pod metadata for log directory path
            - name: POD_NAMESPACE
              valueFrom:
                fieldRef:
                  fieldPath: metadata.namespace
            - name: POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
            - name: POD_UID
              valueFrom:
                fieldRef:
                  fieldPath: metadata.uid
            # Use mounted configuration files
            - name: SPARK_CONF_DIR
              value: "/opt/spark/conf-extra"
          ports:
            - containerPort: 18080
          # Temporarily removed health checks due to missing scripts
          # readinessProbe:
          #   exec:
          #     command: ["./k8s-readiness.sh", "history"]
          #   initialDelaySeconds: 20
          #   periodSeconds: 10
          # livenessProbe:
          #   exec:
          #     command: ["./check-spark-health.sh", "all"]
          #   initialDelaySeconds: 30
          #   periodSeconds: 120
          resources:
            requests:
              cpu: "1"
              memory: "2Gi"
            limits:
              cpu: "2"
              memory: "4Gi"
          volumeMounts:
            - name: spark-events
              mountPath: /mnt/spark/events
            - name: spark-logs-host
              mountPath: /opt/spark/logs
              subPathExpr: $(POD_NAME)
            - name: spark-defaults-conf
              mountPath: /opt/spark/conf-extra
      volumes:
        - name: spark-events
          hostPath:
            path: /mnt/spark/events
            type: DirectoryOrCreate
        - name: spark-logs-host
          hostPath:
            path: /mnt/spark/logs
            type: DirectoryOrCreate
        - name: spark-defaults-conf
          configMap:
            name: spark-defaults-conf
