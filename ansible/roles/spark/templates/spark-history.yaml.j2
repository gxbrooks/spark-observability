apiVersion: apps/v1
kind: Deployment
metadata:
  name: spark-history
  namespace: spark
spec:
  replicas: 1
  selector:
    matchLabels:
      app: spark-history
  template:
    metadata:
      labels:
        app: spark-history
    spec:
      serviceAccountName: spark
      # Add DNS policy for consistency with other components
      dnsPolicy: ClusterFirst
      dnsConfig:
        options:
          - name: ndots
            value: "5"
      containers:
        - name: spark-history
          image: "{{ spark_image }}:{{ spark_tag }}"
          imagePullPolicy: Always
          command: ["/opt/spark/sbin/start-history-server.sh"]
          envFrom:
            - configMapRef:
                name: spark-configmap
          env:
            - name: SPARK_LOCAL_IP
              valueFrom:
                fieldRef:
                  fieldPath: status.podIP
          ports:
            - containerPort: 18080
          # Temporarily removed health checks due to missing scripts
          # readinessProbe:
          #   exec:
          #     command: ["./k8s-readiness.sh", "history"]
          #   initialDelaySeconds: 20
          #   periodSeconds: 10
          # livenessProbe:
          #   exec:
          #     command: ["./check-spark-health.sh", "all"]
          #   initialDelaySeconds: 30
          #   periodSeconds: 120
          resources:
            requests:
              cpu: "1"
              memory: "2Gi"
            limits:
              cpu: "2"
              memory: "4Gi"
          volumeMounts:
            - name: spark-events
              mountPath: /mnt/spark/events
            - name: spark-defaults-conf
              mountPath: /opt/spark/conf/spark-defaults.conf
              subPath: spark-defaults.conf
      volumes:
        - name: spark-events
          hostPath:
            path: /mnt/spark/events
            type: DirectoryOrCreate
        - name: spark-defaults-conf
          configMap:
            name: spark-defaults-conf
