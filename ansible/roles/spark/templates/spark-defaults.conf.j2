# Spark-defaults.conf - Template for runtime configuration
# This template is processed by Ansible to create a ConfigMap that is mounted into containers
# DO NOT EDIT THIS FILE DIRECTLY
#
# For static build-time variables, use vars/variables.yaml with spark-image context
# For dynamic runtime variables, use vars/variables.yaml with spark-runtime context
#
# Default Spark configurations
# Workers inside cluster use: spark://spark-master:7077 (internal service)
# Clients outside cluster use: spark://Lab2.lan:31686 (NodePort)
spark.master                           spark://spark-master:7077
spark.eventLog.enabled                 true
spark.eventLog.dir                     /mnt/spark/events
# Disable event log rolling (v2 format) for compatibility with Elastic Agent monitoring
# V2 format creates compressed .zstd files in directories which Elastic Agent can't parse
spark.eventLog.rolling.enabled         false
spark.eventLog.compression.codec       none
spark.history.fs.logDirectory          /mnt/spark/events
spark.executor.memory                  8g
spark.driver.memory                    4g

# OpenTelemetry Listener for real-time telemetry export
spark.extraListeners                   com.elastic.spark.otel.OTelSparkListener
spark.jars                             /mnt/spark/data/spark-otel-listener-1.0.0.jar

# Network configuration for better DNS resolution
spark.driver.host                      ${SPARK_LOCAL_HOSTNAME}
spark.driver.bindAddress               0.0.0.0
spark.network.timeout                  {{ spark_network_timeout | default('600s') }}
spark.rpc.askTimeout                   {{ spark_rpc_ask_timeout | default('60s') }}
spark.rpc.lookupTimeout                {{ spark_rpc_lookup_timeout | default('60s') }}

# DNS resolution settings
spark.driver.port                      7078
spark.blockManager.port                7079

# Heartbeat settings
spark.executor.heartbeatInterval       {{ spark_executor_heartbeat_interval | default('120s') }}

# Network resilience settings to handle connection resets
spark.network.io.connectionTimeout     120s
spark.network.io.retryWait             5s
spark.network.io.numConnectionsPerPeer 1
spark.shuffle.io.connectionTimeout    120s
spark.shuffle.io.retryWait             5s
spark.shuffle.io.maxRetries            3

# JVM options for GC logging and application logging
# All Spark components write logs to /opt/spark/logs (natural Spark location)
# Pod-specific hostPath mounts ensure no conflicts between pods
spark.executor.extraJavaOptions        -XX:+UseG1GC -Xlog:gc*:file=/opt/spark/logs/gc-executor.log:time,uptime,level,tags:filecount=10,filesize=10M -Dlog4j2.configurationFile=file:///opt/spark/conf-extra/log4j2-cluster.properties
spark.driver.extraJavaOptions          -XX:+UseG1GC -Xlog:gc*:file=/opt/spark/logs/gc-driver.log:time,uptime,level,tags:filecount=10,filesize=10M -Dlog4j2.configurationFile=file:///opt/spark/conf-extra/log4j2-cluster.properties
