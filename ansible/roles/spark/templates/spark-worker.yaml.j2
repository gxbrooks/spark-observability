apiVersion: apps/v1
kind: Deployment
metadata:
  name: spark-worker-lab2
  namespace: spark
spec:
  replicas: 2
  selector:
    matchLabels:
      app: spark-worker
      node: lab2
  template:
    metadata:
      labels:
        app: spark-worker
        node: lab2
    spec:
      serviceAccountName: spark
      # Add tolerations for control-plane taint
      tolerations:
        - key: node-role.kubernetes.io/control-plane
          operator: Exists
          effect: NoSchedule
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
            - matchExpressions:
              - key: kubernetes.io/hostname
                operator: In
                values:
                - lab2
      # Add dnsPolicy and dnsConfig for more reliable DNS resolution
      dnsPolicy: ClusterFirst
      dnsConfig:
        options:
          - name: ndots
            value: "5"
      containers:
        - name: spark-worker
          image: "{{ spark_image }}:{{ spark_tag }}"
          imagePullPolicy: Always
          command: ["/opt/spark/sbin/start-worker.sh", "spark://spark-master-0.spark-master-headless.spark.svc.cluster.local:7077"]
          envFrom:
            - configMapRef:
                name: spark-configmap
          env:
            - name: SPARK_LOCAL_IP
              valueFrom:
                fieldRef:
                  fieldPath: status.podIP
            - name: SPARK_LOCAL_HOSTNAME
              valueFrom:
                fieldRef:
                  fieldPath: status.podIP
          ports:
            - containerPort: 8081
              name: webui
          # Re-enable health checks now that scripts are available
          # Health checks removed - not available in base Apache Spark image
          resources:
            requests:
              cpu: "2"
              memory: "8Gi"
            limits:
              cpu: "4"
              memory: "14Gi"
          volumeMounts:
            - name: spark-events
              mountPath: /mnt/spark/events
            - name: spark-data
              mountPath: /mnt/spark/data
            - name: spark-defaults-conf
              mountPath: /opt/spark/conf/spark-defaults.conf
              subPath: spark-defaults.conf
      volumes:
        - name: spark-events
          hostPath:
            path: /mnt/spark/events
            type: DirectoryOrCreate
        - name: spark-data
          hostPath:
            path: /mnt/spark/data
            type: DirectoryOrCreate
        - name: spark-defaults-conf
          configMap:
            name: spark-defaults-conf
---
