apiVersion: apps/v1
kind: Deployment
metadata:
  name: spark-worker-lab2
  namespace: spark
spec:
  replicas: 2
  selector:
    matchLabels:
      app: spark-worker
      node: lab2
  template:
    metadata:
      labels:
        app: spark-worker
        node: lab2
    spec:
      serviceAccountName: spark
      # Add tolerations for control-plane taint
      tolerations:
        - key: node-role.kubernetes.io/control-plane
          operator: Exists
          effect: NoSchedule
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
            - matchExpressions:
              - key: kubernetes.io/hostname
                operator: In
                values:
                - lab2
      # Add dnsPolicy and dnsConfig for more reliable DNS resolution
      dnsPolicy: ClusterFirst
      dnsConfig:
        options:
          - name: ndots
            value: "5"
      initContainers:
        - name: init-logs
          image: "{{ spark_image }}:{{ spark_tag }}"
          command: ["/bin/bash", "-c"]
          args:
            - |
              mkdir -p /mnt/spark/logs/$(POD_NAME)
              chown -R 185:185 /mnt/spark/logs/$(POD_NAME)
              chmod 755 /mnt/spark/logs/$(POD_NAME)
          env:
            - name: POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
          volumeMounts:
            - name: spark-logs-host
              mountPath: /mnt/spark/logs
          securityContext:
            runAsUser: 0
      containers:
        - name: spark-worker
          image: "{{ spark_image }}:{{ spark_tag }}"
          imagePullPolicy: IfNotPresent
          command: ["/bin/bash", "-c"]
          args: 
            - |
              export SPARK_WORKER_OPTS="-XX:+UseG1GC -Xlog:gc*:file=/opt/spark/logs/gc-worker.log:time,uptime,level,tags:filecount=10,filesize=10M"
              exec /opt/spark/sbin/start-worker.sh spark://spark-master.spark.svc.cluster.local:7077
          envFrom:
            - configMapRef:
                name: spark-configmap
          env:
            - name: SPARK_WORKER_CORES
              value: "4"
            - name: SPARK_LOCAL_IP
              valueFrom:
                fieldRef:
                  fieldPath: status.podIP
            - name: SPARK_LOCAL_HOSTNAME
              valueFrom:
                fieldRef:
                  fieldPath: status.podIP
            # Pod metadata for log directory path
            - name: POD_NAMESPACE
              valueFrom:
                fieldRef:
                  fieldPath: metadata.namespace
            - name: POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
            - name: POD_UID
              valueFrom:
                fieldRef:
                  fieldPath: metadata.uid
            # Use mounted configuration files
            - name: SPARK_CONF_DIR
              value: "/opt/spark/conf-extra"
          ports:
            - containerPort: 8081
              name: webui
          # Re-enable health checks now that scripts are available
          # Health checks removed - not available in base Apache Spark image
          resources:
            requests:
              cpu: "2"
              memory: "8Gi"
            limits:
              cpu: "4"
              memory: "14Gi"
          volumeMounts:
            - name: spark-events
              mountPath: /mnt/spark/events
            - name: spark-data
              mountPath: /mnt/spark/data
            - name: spark-logs-host
              mountPath: /opt/spark/logs
              subPathExpr: $(POD_NAME)
            - name: spark-defaults-conf
              mountPath: /opt/spark/conf-extra
      volumes:
        - name: spark-events
          hostPath:
            path: /mnt/spark/events
            type: DirectoryOrCreate
        - name: spark-data
          hostPath:
            path: /mnt/spark/data
            type: DirectoryOrCreate
        - name: spark-logs-host
          hostPath:
            path: /mnt/spark/logs
            type: DirectoryOrCreate
        - name: spark-defaults-conf
          configMap:
            name: spark-defaults-conf
---
