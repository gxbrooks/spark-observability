apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: spark-master
  namespace: spark
spec:
  serviceName: "spark-master-headless" # Use the headless service for better DNS resolution
  replicas: 1
  selector:
    matchLabels:
      app: spark-master
  template:
    metadata:
      labels:
        app: spark-master
    spec:
      serviceAccountName: spark
      # Add pod hostname and subdomain for better DNS resolution
      hostname: spark-master
      subdomain: spark-master-headless
      # Pin master to Lab2 node
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
            - matchExpressions:
              - key: kubernetes.io/hostname
                operator: In
                values:
                - lab2
      # No init container needed - subPathExpr handles directory creation
      # Add dnsPolicy and dnsConfig for more reliable DNS resolution
      dnsPolicy: ClusterFirst
      dnsConfig:
        options:
          - name: ndots
            value: "5"
      initContainers:
        - name: init-logs
          image: "{{ spark_image }}:{{ spark_tag }}"
          command: ["/bin/bash", "-c"]
          args:
            - |
              mkdir -p /mnt/spark/logs/$(POD_NAME)
              chown -R 185:185 /mnt/spark/logs/$(POD_NAME)
              chmod 755 /mnt/spark/logs/$(POD_NAME)
          env:
            - name: POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
          volumeMounts:
            - name: spark-logs-host
              mountPath: /mnt/spark/logs
          securityContext:
            runAsUser: 0
      containers:
        - name: spark-master
          image: "{{ spark_image }}:{{ spark_tag }}"
          imagePullPolicy: Always
          command: ["/bin/bash", "-c"]
          args: 
            - |
              export SPARK_MASTER_OPTS="-XX:+UseG1GC -Xlog:gc*:file=/opt/spark/logs/gc-master.log:time,uptime,level,tags:filecount=10,filesize=10M"
              exec /opt/spark/sbin/start-master.sh
          envFrom:
            - configMapRef:
                name: spark-configmap
          env:
            # Add explicit environment variables for networking
            - name: SPARK_MASTER_HOST_IP
              valueFrom:
                fieldRef:
                  fieldPath: status.podIP
            # Pod metadata for log directory path
            - name: POD_NAMESPACE
              valueFrom:
                fieldRef:
                  fieldPath: metadata.namespace
            - name: POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
            - name: POD_UID
              valueFrom:
                fieldRef:
                  fieldPath: metadata.uid
            # Use mounted configuration files
            - name: SPARK_CONF_DIR
              value: "/opt/spark/conf-extra"
          ports:
            - containerPort: 7077
              name: spark
            - containerPort: 8080
              name: webui
          # Use simple HTTP health checks that work with official Spark image
          readinessProbe:
            httpGet:
              path: /
              port: 8080
            initialDelaySeconds: 30
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 3
          livenessProbe:
            httpGet:
              path: /
              port: 8080
            initialDelaySeconds: 60
            periodSeconds: 120
            timeoutSeconds: 10
            failureThreshold: 3
          resources:
            requests:
              cpu: "1"
              memory: "2Gi"
            limits:
              cpu: "2"
              memory: "4Gi"
          volumeMounts:
            - name: spark-events
              mountPath: /mnt/spark/events
            - name: spark-data
              mountPath: /mnt/spark/data
            - name: spark-logs-host
              mountPath: /opt/spark/logs
              subPathExpr: $(POD_NAME)
            - name: spark-defaults-conf
              mountPath: /opt/spark/conf-extra
      volumes:
        - name: spark-events
          hostPath:
            path: /mnt/spark/events
            type: DirectoryOrCreate
        - name: spark-data
          hostPath:
            path: /mnt/spark/data
            type: DirectoryOrCreate
        - name: spark-logs-host
          hostPath:
            path: /mnt/spark/logs
            type: DirectoryOrCreate
        - name: spark-defaults-conf
          configMap:
            name: spark-defaults-conf
