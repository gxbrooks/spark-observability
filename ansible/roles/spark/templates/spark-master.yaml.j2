apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: spark-master
  namespace: spark
spec:
  serviceName: "spark-master-headless" # Use the headless service for better DNS resolution
  replicas: 1
  selector:
    matchLabels:
      app: spark-master
  template:
    metadata:
      labels:
        app: spark-master
    spec:
      serviceAccountName: spark
      # Add pod hostname and subdomain for better DNS resolution
      hostname: spark-master
      subdomain: spark-master-headless
      # Add dnsPolicy and dnsConfig for more reliable DNS resolution
      dnsPolicy: ClusterFirst
      dnsConfig:
        options:
          - name: ndots
            value: "5"
      containers:
        - name: spark-master
          image: "{{ spark_image }}:{{ spark_tag }}"
          imagePullPolicy: Always
          command: ["./entrypoint.sh", "master"]
          envFrom:
            - configMapRef:
                name: spark-configmap
          env:
            # Add explicit environment variables for networking
            - name: SPARK_MASTER_HOST_IP
              valueFrom:
                fieldRef:
                  fieldPath: status.podIP
          ports:
            - containerPort: 7077
              name: spark
            - containerPort: 8080
              name: webui
          # Re-enable health checks now that scripts are available
          readinessProbe:
            exec:
              command: ["./k8s-readiness.sh", "master"]
            initialDelaySeconds: 30
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 3
          livenessProbe:
            exec:
              command: ["./check-spark-health.sh", "master"]
            initialDelaySeconds: 60
            periodSeconds: 120
            timeoutSeconds: 10
            failureThreshold: 3
          resources:
            requests:
              cpu: "1"
              memory: "2Gi"
            limits:
              cpu: "2"
              memory: "4Gi"
          volumeMounts:
            - name: spark-events
              mountPath: /mnt/spark-events
            - name: spark-defaults-conf
              mountPath: /opt/spark/conf/spark-defaults.conf
              subPath: spark-defaults.conf
      volumes:
        - name: spark-events
          hostPath:
            path: /mnt/spark-events
            type: DirectoryOrCreate
        - name: spark-defaults-conf
          configMap:
            name: spark-defaults-conf
