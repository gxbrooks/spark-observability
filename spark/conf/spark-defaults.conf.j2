# Spark-defaults.conf for client applications
# This file is GENERATED - do not edit manually!
# Source template: spark/conf/spark-defaults.conf.template
# Generated by: linux/assert_spark_client_apps.sh or linux/generate_spark_defaults.sh
#
# To regenerate: bash vars/generate_env.sh devops && linux/generate_spark_defaults.sh

# Master configuration
spark.master                           spark://Lab2.lan:31686

# Event logging
# Event logs written by Driver to NFS-shared directory
# Accessible by History Server (any cluster node) and Elastic Agent (any host)
spark.eventLog.enabled                 true
spark.eventLog.dir                     /mnt/spark/events
# Disable event log rolling (v2 format) for compatibility with Elastic Agent monitoring
# V2 format creates compressed .zstd files in directories which Elastic Agent can't parse
spark.eventLog.rolling.enabled         false
spark.eventLog.compression.codec       none

# Python configuration - CRITICAL: source vars/contexts/devops/devops_env.sh before running!
# PySpark automatically uses PYSPARK_PYTHON environment variable for executors
# Value set from vars/variables.yaml via devops_env.sh: python3.11

# OpenTelemetry Listener for real-time telemetry export  
# Requires OTEL_EXPORTER_OTLP_ENDPOINT from devops_env.sh
spark.extraListeners                   com.elastic.spark.otel.OTelSparkListener
spark.jars                             {{ SPARK_OTEL_LISTENER_JAR }}
# Pass OTel endpoint to executors
spark.executorEnv.OTEL_EXPORTER_OTLP_ENDPOINT    {{ OTEL_EXPORTER_OTLP_ENDPOINT }}
# Pass Elasticsearch config to executors for event emission
spark.executorEnv.ES_URL                        {{ ES_URL }}
spark.executorEnv.ES_USER                       {{ ES_USER }}
spark.executorEnv.ES_PASSWORD                   {{ ES_PASSWORD }}

# SQL optimizations
spark.sql.adaptive.enabled             true
spark.sql.adaptive.coalescePartitions.enabled  true

# JVM options for GC logging and application logging
# Driver runs locally - basic GC for local development only (not monitored)
# Executors run in Kubernetes - configuration comes from spark-defaults.conf.j2 template
# Driver runs locally - use /tmp for local development (not monitored by Elastic Agent)
spark.driver.extraJavaOptions          -XX:+UseG1GC -Xlog:gc*:file=/tmp/spark-driver-gc.log:time,uptime,level,tags:filecount=10,filesize=10M
# Executors run in Kubernetes - need to pass GC logging options from client
spark.executor.extraJavaOptions        -XX:+UseG1GC -Xlog:gc*:file=/opt/spark/logs/gc-executor.log:time,uptime,level,tags:filecount=10,filesize=10M -Dlog4j2.configurationFile=file:///opt/spark/conf/log4j2-executor.properties


# Driver configuration for client mode
# Driver runs on Lab2 host - must be reachable by workers in K8s pods
# Use IP address since K8s pod DNS cannot resolve Lab2.local
# Note: Set SPARK_LOCAL_IP environment variable to suppress hostname resolution warnings
#       (Set in vars/contexts/devops/devops_env.sh or .bashrc)
spark.driver.host                      192.168.1.48
spark.driver.bindAddress               0.0.0.0

# Network timeouts
spark.network.timeout                  600s
spark.rpc.askTimeout                   60s
spark.rpc.lookupTimeout                60s

# Memory settings
spark.executor.memory                  2g
spark.driver.memory                    1g

