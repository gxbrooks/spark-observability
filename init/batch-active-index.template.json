{
  "index_patterns": [
    "batch-active-index"
  ],
  "priority": 200,
  "template": {
    "settings": {
      "index.number_of_shards": 1,
      "number_of_replicas": 1
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        }
      }
    }
  },
  "composed_of": [
    "logs-mappings",
    "logs-settings"
  ]
}