{
  "index_patterns": [
    "my-data-stream"
  ],
  "data_stream": {},
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "json": {
          "properties": {
            "Properties": {
              "properties": {
                "spark": {
                  "properties": {
                    "rdd": {
                      "type": "object"
                      "properties": {
                        "compress": {
                          "type": "keyword"
                        },
                        "scope": 
                          "type": "object"
                          "properties": {
                            "noOverride": {
                              "type": "keyword"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}