{
  "override": true,
  "refresh_fields": true,
  "data_view": {
    "title": "data-pipeline-ds",
    "name": "Data Pipeline",
    "allowNoIndex" : true,
    "fieldAttrs": {
      "@timestamp": {"customLabel": "Timestamp"},
      "start_time": {"customLabel": "Start Time"},
      "end_time": {"customLabel": "End Time"},
      "start_millis": {"customLabel": "Start Time (millis)"},
      "end_millis": {"customLabel": "End Time (millis)"},
      "duration": {"customLabel": "Duration"},
      "realm": {"customLabel": "Realm"},
      "class": {"customLabel": "Class"},
      "name": {"customLabel": "Operation Name"},
      "id": {"customLabel": "Operation ID"},
      "start_uid": {"customLabel": "Start UID"},
      "end_uid": {"customLabel": "End UID"},
      "parent_key": {"customLabel": "Parent Key"},
      "child_key": {"customLabel": "Child Key"}
    },
    "sourceFilters": [{"value": "parent_uid"}],
    "fieldFormats": {
      "start_time": {
        "id": "date",
        "params": {"pattern": "MM/DD/YYYY HH:mm:ss.SSS"}
      },
      "end_time": {
        "id": "date",
        "params": {"pattern": "MM/DD/YYYY HH:mm:ss.SSS"}
      },
      "start_millis": {"id": "number", "params": {"pattern": "0,0"}},
      "end_millis": {"id": "number"},
      "duration": {"id": "number", "params": {"pattern": "0,0"}}
    }
  }
}