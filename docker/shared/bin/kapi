#!/usr/bin/bash

# conditionalizing on running in a container is probably not needed
# as aliases will be used in the host environment
if [[ -f "/.dockerenv" ]]; then
  # Already running in a Docker container so define the environment
  # Otherwise the environment is defined in the docker-compose.yml file
  if [ ! -v PYTHONPATH ] || [ ! -v PY_SCRIPTS ]; then
    echo "PYTHONPATH not set in environment"
    exit 1
  fi
  python3 ${PY_SCRIPTS}/api/kapi.py $@
  exit $?
else
  docker compose exec es01 kapi $@
  exit $?
fi
