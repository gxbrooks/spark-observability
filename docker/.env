

#########################################################
#
# Global environment variables

# Project namespace (defaults to the current folder name if not set)
#COMPOSE_PROJECT_NAME=myproject

# Set the cluster name
CLUSTER_NAME=docker-cluster

# Set the timezone
TZ=America/Chicago

#########################################################
#
# Spark environment variables

#SPARK_VERSION=3.5.1
SPARK_VERSION=3.5.5
SPARK_HOME=/opt/spark
SPARK_MASTER=spark://spark-master:7077
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
HADOOP_HOME=/opt/hadoop
PYSPARK_PYTHON=python3
SPARK_NO_DAEMONIZE=true

# A relative path may not be consistent between iPython and spark submit
# (but should be)
GOOGLE_APPLICATION_CREDENTIALS=/opt/spark/apps/bq-api-key.json


#########################################################
#
# Elastic environment variables


# Version of Elastic products
# latest is 8.14.0 as of 6/10/2024
#STACK_VERSION=8.14.1
STACK_VERSION=8.7.1

# Password for the 'elastic' user (at least 6 characters)
ELASTIC_PASSWORD=myElastic2025
ELASTIC_USER=elastic
# ELASTIC_URL Being deprecated
ELASTIC_PORT=9200
ELASTIC_HOST=es01
# ELASTIC_HOSTS is being deprecated as logstash requires "[$ELASTIC_URL]" and not just a single endpoint
# Maintain for compatability
ELASTIC_HOSTS=https://es01:9200/
ELASTIC_URL=https://es01:9200/

# Increase or decrease based on the available host memory (in bytes)
ES_MEM_LIMIT=1073741824


#########################################################
#
# Kibana environment variables

# Password for the 'kibana_system' user (at least 6 characters)
KIBANA_PASSWORD=myElastic2025

# Port to expose Kibana to the host
KIBANA_PORT=5601
KIBANA_HOST=kibana
# Set to 'basic' or 'trial' to automatically start the 30-day trial
LICENSE=basic
#LICENSE=trial

# Increase or decrease based on the available host memory (in bytes)
KB_MEM_LIMIT=1073741824

# SAMPLE Predefined Key only to be used in POC environments
# For Kibana only
ENCRYPTION_KEY=c34d38b3a14956121ff2170e5030b471551370178f43e5626eec58b04a30fae2

#########################################################
#
# Logstash environment variables

# Mine
LS_SPARK_EVENTS_PORT=5050
LS_DOCKER_METRICS_PORT=5051
LS_HOST=logstash01

# Increase or decrease based on the available host memory (in bytes)
LS_MEM_LIMIT=1073741824


#########################################################
#
# Elastic Agent environment variables

ELASTIC_AGENT_HOME=/usr/share/elastic-agent
ELASTIC_AGENT_STACK_VERSION=8.15.0

#########################################################
#
# Grafana environment variables

#URL should be http://grafana/ 
# not an official Grafana environment variable
# these look like they are for the host environment and thus suspect
# GF_SERVER_HOST=localhost
# GF_SERVER_ROOT_URL=http://localhost
GF_SERVER_HTTP_PORT=3000
# TODO: enable SSL for Grafana
##GF_SERVER_HTTPS_PORT: The HTTPS port to use.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=mysecretpassword

