{
  "trigger": {"schedule": {"interval": "5m"}},
  "input": {
    "search": {
      "request": {
        "indices": ["batch-events"],
        "body": {
          "size": 1,
          "query": {
            "dis_max": {
              "queries": [
                {"term": {"matched": true}},
                {"term": {"event_kind": "Point"}}
              ]
            }
          }
        }
      }
    }
  },
  "condition": {"compare": {"ctx.payload.hits.total": {"gt": 0}}},
  "actions": {
    "delete_matched": {
      "webhook": {
        "method": "POST",
        "url": "https://es01:9200/batch-events/_delete_by_query",
        "auth": {"basic": {"username": "elastic", "password": "changeme"}},
        "headers": {"Content-Type": "application/json"},
        "body": "{ \"size\": 100, \"query\": { \"dis_max\": { \"queries\": [ {\"term\": {\"matched\": true}}, {\"term\": {\"event_kind\": \"Point\"}} ] } } } "
      }
    }
  }
}