
# TODO: Need to reconcile with .env file, which currently has all SPARK env variables
#       Possibly because of a misunderstanding of relative working directories in Dockerfile and docker compose
SPARK_HOME=/opt/spark
SPARK_MASTER=spark://spark-master:7077
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
HADOOP_HOME=/opt/spark
PYSPARK_PYTHON=python3
SPARK_NO_DAEMONIZE=true
#SPARK_VERSION=3.5.1
SPARK_VERSION=3.5.5

# If you need to add Spark dirs to the PATH, it is done in the Dockerfile or you need to add it
# yourself. This is to avoid duplicate additions. 

