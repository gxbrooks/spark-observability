  "tiles": {
    "1": {
      "type": "markdown",
      "content": "## Hosts (Lab1, Lab2, Lab3)\nPer-host breakdown mirroring Grafana **Hosts**. Aggregated view: **Spark System Metrics**."
    },
    "2": {
      "type": "data",
      "title": "Host Compute Saturation",
      "visualization": "lineChart",
      "subType": "dql-builder-metrics",
      "query": "timeseries cpu=avg(dt.host.cpu.usage), by:{dt.entity.host}\n| fieldsAdd host=entityName(dt.entity.host)\n| filter in(host, \"Lab1\", \"Lab2\", \"Lab3\")\n| fieldsRemove dt.entity.host",
      "querySettings": { "enableSampling": false, "maxResultRecords": 1000, "maxResultMegaBytes": 1 },
      "visualizationSettings": { "autoSelectVisualization": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "3": {
      "type": "data",
      "title": "Host Load Trend",
      "visualization": "lineChart",
      "subType": "dql-builder-metrics",
      "query": "timeseries load=avg(dt.host.cpu.load), by:{dt.entity.host}\n| fieldsAdd host=entityName(dt.entity.host)\n| filter in(host, \"Lab1\", \"Lab2\", \"Lab3\")\n| fieldsRemove dt.entity.host",
      "querySettings": { "enableSampling": false, "maxResultRecords": 1000, "maxResultMegaBytes": 1 },
      "visualizationSettings": { "autoSelectVisualization": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "4": {
      "type": "data",
      "title": "GPU Compute Use",
      "visualization": "lineChart",
      "subType": "dql-builder-metrics",
      "query": "timeseries core=avg(system.gpu.utilization.core_percent), by:{host.name}\n| filter in(host.name, \"Lab1\", \"Lab2\", \"Lab3\", \"lab1\", \"lab2\", \"lab3\")",
      "querySettings": { "enableSampling": false, "maxResultRecords": 1000, "maxResultMegaBytes": 1 },
      "visualizationSettings": { "autoSelectVisualization": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "5": {
      "type": "data",
      "title": "GPU Die Temperature",
      "visualization": "lineChart",
      "subType": "dql-builder-metrics",
      "query": "timeseries temp=avg(system.gpu.temperature_c.edge), by:{host.name}\n| filter in(host.name, \"Lab1\", \"Lab2\", \"Lab3\", \"lab1\", \"lab2\", \"lab3\")",
      "querySettings": { "enableSampling": false, "maxResultRecords": 1000, "maxResultMegaBytes": 1 },
      "visualizationSettings": { "autoSelectVisualization": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "6": {
      "type": "data",
      "title": "Network Throughput",
      "visualization": "lineChart",
      "subType": "dql-builder-metrics",
      "query": "timeseries {rx=avg(dt.host.net.nic.bytes_rx), tx=avg(dt.host.net.nic.bytes_tx)}, by:{dt.entity.host}\n| fieldsAdd host=entityName(dt.entity.host)\n| filter in(host, \"Lab1\", \"Lab2\", \"Lab3\")\n| fieldsRemove dt.entity.host\n| fieldsAdd tx = tx[] * -1",
      "querySettings": { "enableSampling": false, "maxResultRecords": 1000, "maxResultMegaBytes": 1 },
      "visualizationSettings": { "autoSelectVisualization": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "7": {
      "type": "data",
      "title": "Disk Throughput",
      "visualization": "lineChart",
      "subType": "dql-builder-metrics",
      "query": "timeseries {read=avg(dt.host.disk.bytes_read), write=avg(dt.host.disk.bytes_written)}, by:{dt.entity.host}\n| fieldsAdd host=entityName(dt.entity.host)\n| filter in(host, \"Lab1\", \"Lab2\", \"Lab3\")\n| fieldsRemove dt.entity.host\n| fieldsAdd write = write[] * -1",
      "querySettings": { "enableSampling": false, "maxResultRecords": 1000, "maxResultMegaBytes": 1 },
      "visualizationSettings": { "autoSelectVisualization": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "8": {
      "type": "data",
      "title": "Memory Fault Rate (faults/s)",
      "visualization": "lineChart",
      "subType": "dql-builder-metrics",
      "query": "timeseries pf=avg(dt.host.memory.avail.pfps), by:{dt.entity.host}\n| fieldsAdd host=entityName(dt.entity.host)\n| filter in(host, \"Lab1\", \"Lab2\", \"Lab3\")\n| fieldsRemove dt.entity.host",
      "querySettings": { "enableSampling": false, "maxResultRecords": 1000, "maxResultMegaBytes": 1 },
      "visualizationSettings": { "autoSelectVisualization": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "9": {
      "type": "data",
      "title": "Host Memory Pressure",
      "visualization": "lineChart",
      "subType": "dql-builder-metrics",
      "query": "timeseries mem=avg(dt.host.memory.usage), by:{dt.entity.host}\n| fieldsAdd host=entityName(dt.entity.host)\n| filter in(host, \"Lab1\", \"Lab2\", \"Lab3\")\n| fieldsRemove dt.entity.host",
      "querySettings": { "enableSampling": false, "maxResultRecords": 1000, "maxResultMegaBytes": 1 },
      "visualizationSettings": { "autoSelectVisualization": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    }
  }
