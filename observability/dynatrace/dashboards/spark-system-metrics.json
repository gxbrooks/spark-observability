      "title": "Stage Shuffle (Write Positive)",
      "visualization": "lineChart",
      "subType": "dql-builder-metrics",
      "query": "timeseries interval: 5s, {read=sum(spark.stage.shuffle.read.bytes.count, rate:1s, default: 0), write=sum(spark.stage.shuffle.write.bytes.count, rate:1s, default: 0)}",
      "querySettings": { "enableSampling": false, "maxResultRecords": 1000, "maxResultMegaBytes": 1 },
      "visualizationSettings": { "autoSelectVisualization": false },
