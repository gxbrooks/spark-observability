    "16": {
      "type": "data",
      "title": "Active Executions",
      "visualization": "barChart",
      "subType": "dql-builder-metrics",
      "query": "timeseries interval: 5s, {app=max(spark.executions.active.app, default: 0), job=max(spark.executions.active.job, default: 0), stage=max(spark.executions.active.stage, default: 0), task=max(spark.executions.active.task, default: 0), sql=max(spark.executions.active.sql, default: 0)}",
      "querySettings": { "enableSampling": false, "maxResultRecords": 1000, "maxResultMegaBytes": 1 },
      "visualizationSettings": {
        "autoSelectVisualization": false,
        "chartSettings": { "stacked": true, "legend": { "position": "bottom", "showLegend": true } }
      },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "17": {
