{
  "schemaId": "builtin:management-zones",
  "scope": "environment",
  "value": {
    "name": "{{ DT_MANAGEMENT_ZONE }}",
    "rules": [
      {
        "enabled": true,
        "type": "ME",
        "attributeRule": {
          "entityType": "HOST",
          "conditions": [
            {
              "key": "HOST_GROUP_NAME",
              "operator": "EQUALS",
              "stringValue": "{{ DT_HOST_GROUP }}",
              "caseSensitive": false
            }
          ],
          "serviceToHostPropagation": false,
          "serviceToPGPropagation": false,
          "pgToHostPropagation": false,
          "pgToServicePropagation": false,
          "hostToPGPropagation": true,
          "customDeviceGroupToCustomDevicePropagation": false,
          "azureToServicePropagation": false,
          "azureToPGPropagation": false
        }
      },
      {
        "enabled": true,
        "type": "ME",
        "attributeRule": {
          "entityType": "KUBERNETES_CLUSTER",
          "conditions": [
            {
              "key": "KUBERNETES_CLUSTER_NAME",
              "operator": "EQUALS",
              "stringValue": "{{ K8S_DYNATRACE_CLUSTER }}",
              "caseSensitive": false
            }
          ],
          "serviceToHostPropagation": false,
          "serviceToPGPropagation": false,
          "pgToHostPropagation": false,
          "pgToServicePropagation": false,
          "hostToPGPropagation": false,
          "customDeviceGroupToCustomDevicePropagation": false,
          "azureToServicePropagation": false,
          "azureToPGPropagation": false
        }
      },
      {
        "enabled": true,
        "type": "ME",
        "attributeRule": {
          "entityType": "CUSTOM_DEVICE",
          "conditions": [
            {
              "key": "CUSTOM_DEVICE_NAME",
              "operator": "EQUALS",
              "stringValue": "{{ dt_sn_spark_client_custom_device_display_name | default('Spark Client') }}",
              "caseSensitive": false
            }
          ],
          "serviceToHostPropagation": false,
          "serviceToPGPropagation": false,
          "pgToHostPropagation": false,
          "pgToServicePropagation": false,
          "hostToPGPropagation": false,
          "customDeviceGroupToCustomDevicePropagation": false,
          "azureToServicePropagation": false,
          "azureToPGPropagation": false
        }
      }
    ]
  }
}
