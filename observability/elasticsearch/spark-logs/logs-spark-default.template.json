{
  "index_patterns": [
    "logs-spark-default"
  ],
  "data_stream": {},
  "priority": 200,
  "template": {
    "settings": {
      "index.number_of_shards": 1,
      "number_of_replicas": 1,
      "index.mapping.depth.limit": 50,
      "index.mapping.nested_objects.limit": 100,
      "index.lifecycle.name": "spark-logs",
      "index.lifecycle.rollover_alias": "spark-logs-alias",
      "index.default_pipeline": "spark-logs-pipeline"
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "log": {
          "properties": {
            "level": {
              "type": "keyword"
            }
          }
        },
        "spark": {
          "properties": {
            "component": {
              "type": "keyword"
            },
            "pod_name": {
              "type": "keyword"
            },
            "class": {
              "type": "keyword"
            }
          }
        },
        "message": {
          "type": "text",
          "fields": {
            "keyword": {
              "type": "keyword",
              "ignore_above": 256
            }
          }
        },
        "error": {
          "properties": {
            "stack_trace": {
              "type": "text",
              "fields": {
                "keyword": {
                  "type": "keyword",
                  "ignore_above": 1024
                }
              }
            }
          }
        },
        "log_message": {
          "type": "text"
        }
      }
    }
  },
  "composed_of": [
    "logs-mappings",
    "logs-settings"
  ]
}