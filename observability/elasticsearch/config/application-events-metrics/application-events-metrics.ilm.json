{
  "policy": {
    "phases": {
      "hot": {
        "min_age": "0ms",
        "actions": {
          "rollover": {
            "max_age": "1d",
            "max_primary_shard_size": "50gb"
          },
          "downsample": {
            "fixed_interval": "5m"
          },
          "set_priority": {
            "priority": 100
          }
        }
      },
      "warm": {
        "min_age": "4d",
        "actions": {
          "downsample": {
            "fixed_interval": "15m"
          },
          "set_priority": {
            "priority": 50
          }
        }
      },
      "cold": {
        "min_age": "8d",
        "actions": {
          "downsample": {
            "fixed_interval": "60m"
          },
          "set_priority": {
            "priority": 25
          }
        }
      },
      "delete": {
        "min_age": "730d",
        "actions": {
          "delete": {}
        }
      }
    }
  }
}

