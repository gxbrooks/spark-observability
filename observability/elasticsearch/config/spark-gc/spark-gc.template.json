{
  "index_patterns": ["logs-spark_gc-default"],
  "data_stream": {},
  "priority": 200,
  "template": {
    "settings": {
      "index.number_of_shards": 1,
      "number_of_replicas": 1,
      "index.lifecycle.name": "spark-gc",
      "index.lifecycle.rollover_alias": "spark-gc-alias",
      "index.default_pipeline": "logs-spark_gc-default"
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "@timestamp": {"type": "date"},
        "message": {"type": "text"},
        "log": {
          "properties": {
            "file": {
              "properties": {
                "path": {"type": "keyword"}
              }
            }
          }
        },
        "agent": {
          "properties": {
            "hostname": {"type": "keyword"}
          }
        },
        "spark": {
          "properties": {
            "component_type": {"type": "keyword"},
            "pod_directory": {"type": "keyword"},
            "pod": {
              "properties": {
                "pod_name": {"type": "keyword"}
              }
            },
            "metadata": {
              "properties": {
                "host": {"type": "keyword"},
                "deployment_type": {"type": "keyword"},
                "pod_name": {"type": "keyword"},
                "spark_role": {"type": "keyword"}
              }
            }
          }
        },
        "gc": {
          "properties": {
            "paused": {
              "properties": {
                "gc_timestamp": {"type": "date"},
                "cycle": {"type": "long"},
                "type": {"type": "keyword"},
                "kind": {"type": "keyword"},
                "before": {"type": "long"},
                "after": {"type": "long"},
                "heapsize": {"type": "long"},
                "millis": {"type": "float"},
                "reclaimed": {"type": "long"}
              }
            },
            "start": {
              "properties": {
                "gc_timestamp": {"type": "date"},
                "cycle": {"type": "long"},
                "type": {"type": "keyword"},
                "kind": {"type": "keyword"}
              }
            },
            "stats": {"type": "keyword"},
            "level": {"type": "keyword"},
            "tags": {"type": "keyword"},
            "ingest_time": {"type": "date"}
          }
        },
        "container": {
          "properties": {
            "id": {"type": "keyword"},
            "name": {"type": "keyword"},
            "image": {
              "properties": {
                "name": {"type": "keyword"},
                "tag": {"type": "keyword"}
              }
            },
            "runtime": {"type": "keyword"}
          }
        },
        "kubernetes": {
          "properties": {
            "namespace": {"type": "keyword"},
            "pod": {
              "properties": {
                "name": {"type": "keyword"},
                "uid": {"type": "keyword"}
              }
            },
            "node": {
              "properties": {
                "name": {"type": "keyword"}
              }
            },
            "labels": {
              "type": "object",
              "properties": {
                "app": {"type": "keyword"},
                "component": {"type": "keyword"},
                "instance": {"type": "keyword"}
              }
            }
          }
        }
      }
    }
  }
}