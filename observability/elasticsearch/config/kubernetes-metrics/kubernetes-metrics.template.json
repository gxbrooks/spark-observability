{
  "index_patterns": [
    "metrics-kubernetes-*"
  ],
  "data_stream": {},
  "priority": 210,
  "template": {
    "settings": {
      "index.number_of_shards": 1,
      "number_of_replicas": 1,
      "index.lifecycle.name": "kubernetes-metrics-downsampled",
      "index.mapping.total_fields.limit": 10000
    },
    "mappings": {
      "dynamic": true,
      "dynamic_templates": [
        {
          "long_metrics": {
            "match_mapping_type": "long",
            "mapping": {
              "type": "long",
              "doc_values": true
            }
          }
        },
        {
          "float_metrics": {
            "match_mapping_type": "double",
            "mapping": {
              "type": "float",
              "doc_values": true
            }
          }
        },
        {
          "double_metrics": {
            "mapping": {
              "type": "double",
              "doc_values": true
            }
          }
        },
        {
          "histogram_metrics": {
            "mapping": {
              "type": "histogram"
            }
          }
        },
        {
          "summary_metrics": {
            "mapping": {
              "type": "aggregate_metric_double",
              "metrics": ["sum", "value_count"],
              "default_metric": "value_count"
            }
          }
        }
      ],
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "prometheus": {
          "properties": {
            "metric": {
              "properties": {
                "name": {
                  "type": "keyword"
                },
                "type": {
                  "type": "keyword"
                }
              }
            }
          }
        },
        "kubernetes": {
          "properties": {
            "namespace": {
              "type": "keyword"
            },
            "pod": {
              "properties": {
                "name": {
                  "type": "keyword"
                },
                "uid": {
                  "type": "keyword"
                }
              }
            },
            "node": {
              "properties": {
                "name": {
                  "type": "keyword"
                }
              }
            },
            "service": {
              "properties": {
                "name": {
                  "type": "keyword"
                }
              }
            },
            "deployment": {
              "properties": {
                "name": {
                  "type": "keyword"
                }
              }
            }
          }
        },
        "phase": {
          "type": "keyword"
        },
        "labels": {
          "type": "object",
          "enabled": true
        },
        "scrape_job": {
          "type": "keyword"
        },
        "container_cgroup_path": {
          "type": "keyword",
          "ignore_above": 4096
        }
      }
    }
  }
}


