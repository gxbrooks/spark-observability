{
  "override": true,
  "refresh_fields": true,
  "data_view": {
    "title": "metrics-kubernetes-*",
    "id": "kubernetes-metrics",
    "name": "Kubernetes Metrics",
    "allowNoIndex": true,
    "timeFieldName": "@timestamp",
    "fieldAttrs": {
      "@timestamp":          {"customLabel": "Timestamp"},
      "service.name":        {"customLabel": "Job (Prometheus)"},
      "service.node.name":   {"customLabel": "Instance"},
      "cluster":             {"customLabel": "Cluster"},
      "environment":         {"customLabel": "Environment"},
      "kubernetes_namespace":{"customLabel": "Namespace (label)"},
      "kubernetes_node":     {"customLabel": "Node (label)"},
      "kubernetes_service":  {"customLabel": "Service (label)"},
      "container":           {"customLabel": "Container"},
      "pod":                 {"customLabel": "Pod"},
      "namespace":           {"customLabel": "Namespace"},
      "node":                {"customLabel": "Node"}
    },
    "fieldFormats": {
      "@timestamp": {
        "id": "date",
        "params": {"pattern": "MM/DD/YYYY HH:mm:ss.SSS"}
      }
    },
    "sourceFilters": []
  }
}
