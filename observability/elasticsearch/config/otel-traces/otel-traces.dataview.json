{
  "override": true,
  "refresh_fields": true,
  "data_view": {
    "title": "traces-otel-default*",
    "id": "otel-traces",
    "name": "OpenTelemetry Traces",
    "allowNoIndex": true,
    "timeFieldName": "@timestamp",
    "fieldAttrs": {
      "@timestamp": {"customLabel": "Timestamp"},
      "trace.id": {"customLabel": "Trace ID"},
      "span.id": {"customLabel": "Span ID"},
      "parent.id": {"customLabel": "Parent Span ID"},
      "span.name": {"customLabel": "Span Name"},
      "span.kind": {"customLabel": "Operation Hierarchy"},
      "application": {"customLabel": "Application"},
      "operation.type": {"customLabel": "Operation Type"},
      "event.outcome": {"customLabel": "Outcome"},
      "service.name": {"customLabel": "Service Name"},
      "service.namespace": {"customLabel": "Service Namespace"},
      "service.environment": {"customLabel": "Environment"},
      "spark.app.id": {"customLabel": "Spark App ID"},
      "spark.app.name": {"customLabel": "Spark App Name"},
      "spark.user": {"customLabel": "Spark User"},
      "spark.job.id": {"customLabel": "Job ID"},
      "spark.job.result": {"customLabel": "Job Result"},
      "spark.job.stage.count": {"customLabel": "Stage Count"},
      "spark.job.stages": {"customLabel": "Job Stages"},
      "spark.job.sql.execution.id": {"customLabel": "SQL Execution ID"},
      "spark.stage.id": {"customLabel": "Stage ID"},
      "spark.stage.name": {"customLabel": "Stage Name"},
      "spark.stage.num.tasks": {"customLabel": "Num Tasks"},
      "spark.stage.tasks.completed": {"customLabel": "Tasks Completed"},
      "spark.stage.result": {"customLabel": "Stage Result"},
      "spark.stage.shuffle.read.bytes": {"customLabel": "Shuffle Read"},
      "spark.stage.shuffle.write.bytes": {"customLabel": "Shuffle Write"},
      "spark.stage.input.bytes": {"customLabel": "Input Bytes"},
      "spark.stage.output.bytes": {"customLabel": "Output Bytes"},
      "spark.task.id": {"customLabel": "Task ID"},
      "spark.task.index": {"customLabel": "Task Index"},
      "spark.task.executor.id": {"customLabel": "Executor ID"},
      "spark.task.executor.run.time.ms": {"customLabel": "Executor Run Time"},
      "spark.task.executor.cpu.time.ms": {"customLabel": "Executor CPU Time"},
      "spark.task.result.size.bytes": {"customLabel": "Result Size"},
      "spark.sql.execution.id": {"customLabel": "SQL Execution ID"},
      "spark.sql.description": {"customLabel": "SQL Query"},
      "spark.sql.physical_plan": {"customLabel": "Physical Plan"}
    },
    "fieldFormats": {
      "@timestamp": {
        "id": "date",
        "params": {"pattern": "MM/DD/YYYY HH:mm:ss.SSS"}
      },
      "application": {
        "id": "string"
      },
      "operation.type": {
        "id": "string"
      },
      "spark.stage.shuffle.read.bytes": {
        "id": "bytes",
        "params": {"pattern": "0,0.0 b"}
      },
      "spark.stage.shuffle.write.bytes": {
        "id": "bytes",
        "params": {"pattern": "0,0.0 b"}
      },
      "spark.stage.input.bytes": {
        "id": "bytes",
        "params": {"pattern": "0,0.0 b"}
      },
      "spark.stage.output.bytes": {
        "id": "bytes",
        "params": {"pattern": "0,0.0 b"}
      },
      "spark.task.result.size.bytes": {
        "id": "bytes",
        "params": {"pattern": "0,0.0 b"}
      },
      "spark.task.executor.run.time.ms": {
        "id": "duration",
        "params": {"inputFormat": "milliseconds", "outputFormat": "humanizePrecise"}
      },
      "spark.task.executor.cpu.time.ms": {
        "id": "duration",
        "params": {"inputFormat": "milliseconds", "outputFormat": "humanizePrecise"}
      }
    }
  }
}
