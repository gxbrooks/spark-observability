{
  "index_patterns": ["otel-traces-*"],
  "priority": 500,
  "template": {
    "settings": {
      "number_of_shards": 2,
      "number_of_replicas": 1,
      "index.lifecycle.name": "otel-traces-policy",
      "index.codec": "best_compression",
      "index.mapping.total_fields.limit": 2000,
      "index.refresh_interval": "5s"
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date",
          "format": "epoch_millis||strict_date_optional_time||yyyy-MM-dd HH:mm:ss.SSS"
        },
        "trace_id": {
          "type": "keyword",
          "ignore_above": 256
        },
        "span_id": {
          "type": "keyword",
          "ignore_above": 256
        },
        "parent_span_id": {
          "type": "keyword",
          "ignore_above": 256
        },
        "name": {
          "type": "keyword",
          "ignore_above": 512
        },
        "kind": {
          "type": "keyword"
        },
        "start_time_unix_nano": {
          "type": "long"
        },
        "end_time_unix_nano": {
          "type": "long"
        },
        "duration_nano": {
          "type": "long"
        },
        "duration_ms": {
          "type": "float"
        },
        "status": {
          "properties": {
            "code": {
              "type": "keyword"
            },
            "message": {
              "type": "text"
            }
          }
        },
        "attributes": {
          "type": "object",
          "dynamic": true,
          "properties": {
            "spark.app.name": {"type": "keyword"},
            "spark.app.id": {"type": "keyword"},
            "spark.user": {"type": "keyword"},
            "spark.job.id": {"type": "long"},
            "spark.job.stage.count": {"type": "long"},
            "spark.job.result": {"type": "keyword"},
            "spark.job.error": {"type": "text"},
            "spark.stage.id": {"type": "long"},
            "spark.stage.name": {"type": "keyword"},
            "spark.stage.num.tasks": {"type": "long"},
            "spark.stage.attempt": {"type": "long"},
            "spark.stage.is.retry": {"type": "boolean"},
            "spark.stage.tasks.completed": {"type": "long"},
            "spark.stage.shuffle.read.bytes": {"type": "long"},
            "spark.stage.shuffle.write.bytes": {"type": "long"},
            "spark.stage.input.bytes": {"type": "long"},
            "spark.stage.output.bytes": {"type": "long"},
            "spark.stage.memory.spilled.bytes": {"type": "long"},
            "spark.stage.disk.spilled.bytes": {"type": "long"},
            "spark.stage.result": {"type": "keyword"},
            "spark.stage.error": {"type": "text"},
            "spark.task.id": {"type": "long"},
            "spark.task.index": {"type": "long"},
            "spark.task.attempt": {"type": "long"},
            "spark.task.stage.id": {"type": "long"},
            "spark.task.executor.id": {"type": "keyword"},
            "spark.task.executor.run.time.ms": {"type": "long"},
            "spark.task.executor.cpu.time.ms": {"type": "long"},
            "spark.task.result.size.bytes": {"type": "long"},
            "spark.task.failure.reason": {"type": "text"},
            "service.name": {"type": "keyword"},
            "service.namespace": {"type": "keyword"}
          }
        },
        "resource": {
          "type": "object",
          "properties": {
            "service.name": {"type": "keyword"},
            "service.namespace": {"type": "keyword"},
            "deployment.environment": {"type": "keyword"},
            "k8s.cluster.name": {"type": "keyword"},
            "k8s.namespace.name": {"type": "keyword"},
            "k8s.pod.name": {"type": "keyword"},
            "k8s.node.name": {"type": "keyword"},
            "host.name": {"type": "keyword"}
          }
        },
        "events": {
          "type": "nested",
          "properties": {
            "name": {"type": "keyword"},
            "time_unix_nano": {"type": "long"},
            "attributes": {"type": "object", "dynamic": true}
          }
        },
        "links": {
          "type": "nested",
          "properties": {
            "trace_id": {"type": "keyword"},
            "span_id": {"type": "keyword"}
          }
        }
      }
    }
  }
}

