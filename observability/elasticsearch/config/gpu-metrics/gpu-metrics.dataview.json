      },
      "gpu.utilization.memory_percent": {
        "name": "gpu.utilization.memory_percent",
        "type": "number",
        "customLabel": "VRAM Utilization % (Raw)"
      },
      "gpu.utilization.core_percent_normalized": {
        "name": "gpu.utilization.core_percent_normalized",
