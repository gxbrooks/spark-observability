      "title": "Network Byte Rates",
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "alias": "Trailing Inbound Bytes",
            "mode": "windowFunctions",
            "reduce": {
              "reducer": "sum"
            },
            "window": {
              "field": "Average docker.network.inbound.bytes",
              "reducer": "mean",
              "windowAlignment": "trailing",
              "windowSize": 10,
              "windowSizeMode": "fixed"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Trailing Outbound Bytes",
            "mode": "windowFunctions",
            "reduce": {
              "reducer": "sum"
            },
            "window": {
              "field": "Average docker.network.outbound.bytes",
              "reducer": "mean",
              "windowAlignment": "trailing",
              "windowSize": 10,
              "windowSizeMode": "fixed"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Inbound Byte Rate",
            "binary": {
              "left": "Average docker.network.inbound.bytes",
              "operator": "-",
              "right": "Trailing Inbound Bytes"
            },
            "mode": "binary",
            "reduce": {
              "reducer": "sum"
            },
            "replaceFields": false
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Outbound Byte Rate",
            "binary": {
              "left": "Average docker.network.outbound.bytes",
              "operator": "-",
              "right": "Trailing Outbound Bytes"
            },
            "mode": "binary",
            "reduce": {
              "reducer": "sum"
            },
            "replaceFields": false
          }
        }
      ],
      "type": "timeseries"
