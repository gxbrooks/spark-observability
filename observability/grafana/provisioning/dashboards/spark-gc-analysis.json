      "pluginVersion": "8.7.1",
      "targets": [
        {
          "bucketAggs": [
            {
              "field": "host.name",
              "id": "1",
              "settings": {
                "min_doc_count": "1",
                "order": "desc",
                "orderBy": "_term",
                "size": "10"
              },
              "type": "terms"
            },
            {
              "field": "@timestamp",
              "id": "2",
              "settings": {
                "interval": "auto"
              },
              "type": "date_histogram"
            }
          ],
          "datasource": {
            "type": "elasticsearch",
            "uid": "spark-elasticsearch"
          },
          "metrics": [
            {
              "field": "system.cpu.total.pct",
              "id": "1",
              "type": "avg"
            }
          ],
          "query": "_index:metrics-system.cpu-default",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
