              ],
              "externalStyles":
              [],
              "helpers": "context.handlebars.registerHelper(\"formatTimestamp\", function (ts) {\n  if (!ts) return ts;\n  try {\n    const date = new Date(Number(ts)); // convert to number\n    if (isNaN(date.getTime())) return ts; // handle invalid date\n    return date.toLocaleString(\"en-US\", {\n      year: \"numeric\",\n      month: \"short\",\n      day: \"2-digit\",\n      hour: \"2-digit\",\n      minute: \"2-digit\",\n      second: \"2-digit\",\n      hour12: false\n    });\n  } catch (e) {\n    return ts;\n  }\n});\n\ncontext.handlebars.registerHelper(\"escape\", function (text) {\n  if (typeof text !== \"string\") return text;\n  return text\n    .replace(/&/g, \"&amp;\")\n    .replace(/</g, \"&lt;\")\n    .replace(/>/g, \"&gt;\")\n    .replace(/\"/g, \"&quot;\")\n    .replace(/'/g, \"&#039;\");\n});",
              "renderMode": "allRows",
