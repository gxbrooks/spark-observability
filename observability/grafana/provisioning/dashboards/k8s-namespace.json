      "targets": [
        {
          "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
          "query": "_index:.ds-metrics-kubernetes-default* AND scrape_job:kubernetes-cadvisor AND _exists_:container_network_receive_bytes_total AND interface.keyword:eth0",
          "alias": "{{term kubernetes.namespace}} In",
          "metrics": [
