          "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
          "query": "_index:.ds-metrics-kubernetes-default* AND scrape_job:kubernetes-cadvisor AND _exists_:container_network_transmit_bytes_total AND interface.keyword:eth0",
