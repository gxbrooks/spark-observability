            { "id": "2", "type": "derivative", "field": "1", "pipelineAgg": "1", "settings": { "unit": "$__interval" }, "hide": true },
            { "id": "3", "type": "bucket_script", "pipelineAgg": "2", "settings": { "script": "params._value != null && params._value >= 0 ? params._value * -1 : (params._max != null ? -(params._max / 60.0) : null)" }, "pipelineVariables": [ { "name": "_value", "pipelineAgg": "2" }, { "name": "_max", "pipelineAgg": "1" } ] }
          ],
          "bucketAggs": [
            { "id": "4", "type": "terms", "field": "kubernetes.namespace", "settings": { "min_doc_count": "1", "order": "desc", "orderBy": "_count", "size": "20" } },
