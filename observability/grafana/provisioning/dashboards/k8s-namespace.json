    {
      "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
      "description": "Envelope: receives (Rx) negative, transmits (Tx) positive. Bytes/sec by namespace (eth0, loopback excluded). Source: cAdvisor container_network_*_bytes_total. SRE signal: Traffic.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Bytes/sec",
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 1,
            "spanNulls": true,
            "showPoints": "never",
            "axisCenteredZero": true
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": [] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
          "query": "attributes.scrape_job.keyword:kubernetes-cadvisor AND prometheus.metric.name:container_network_receive_bytes_total AND interface.keyword:eth0",
          "alias": "{{term kubernetes.namespace}} In",
          "metrics": [
            { "id": "1", "type": "max", "field": "value", "hide": true },
            { "id": "2", "type": "derivative", "field": "1", "pipelineAgg": "1", "settings": { "unit": "$__interval" }, "hide": true },
            { "id": "3", "type": "bucket_script", "pipelineAgg": "2", "settings": { "script": "params._value != null && params._value >= 0 ? params._value * -1 : (params._max != null ? -(params._max / 60.0) : null)" }, "pipelineVariables": [ { "name": "_value", "pipelineAgg": "2" }, { "name": "_max", "pipelineAgg": "1" } ] }
          ],
          "bucketAggs": [
            { "id": "4", "type": "terms", "field": "kubernetes.namespace", "settings": { "min_doc_count": "1", "order": "desc", "orderBy": "_count", "size": "20" } },
            { "id": "5", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "$__interval" } }
          ],
          "refId": "A",
          "timeField": "@timestamp"
        },
        {
          "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
          "query": "attributes.scrape_job.keyword:kubernetes-cadvisor AND prometheus.metric.name:container_network_transmit_bytes_total AND interface.keyword:eth0",
          "alias": "{{term kubernetes.namespace}} Out",
          "metrics": [
            { "id": "1", "type": "max", "field": "value", "hide": true },
            { "id": "2", "type": "derivative", "field": "1", "pipelineAgg": "1", "settings": { "unit": "$__interval" }, "hide": true },
            { "id": "3", "type": "bucket_script", "pipelineAgg": "2", "settings": { "script": "params._value != null && params._value >= 0 ? params._value : (params._max != null ? params._max / 60.0 : null)" }, "pipelineVariables": [ { "name": "_value", "pipelineAgg": "2" }, { "name": "_max", "pipelineAgg": "1" } ] }
          ],
          "bucketAggs": [
            { "id": "4", "type": "terms", "field": "kubernetes.namespace", "settings": { "min_doc_count": "1", "order": "desc", "orderBy": "_count", "size": "20" } },
            { "id": "5", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "$__interval" } }
          ],
          "refId": "B",
          "timeField": "@timestamp"
        }
      ],
      "title": "Network Byte Rate by Namespace (In/Out)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
      "description": "Rate of network packets dropped on receive per namespace. SRE signal: Errors.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisLabel": "Packets/interval", "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "spanNulls": true },
          "unit": "pps",
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 100 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": [] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
          "query": "attributes.scrape_job.keyword:kubernetes-cadvisor AND prometheus.metric.name:container_network_receive_packets_dropped_total AND interface.keyword:eth0",
