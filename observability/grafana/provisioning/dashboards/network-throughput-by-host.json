{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["spark", "drilldown", "network"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Host Network Throughput",
  "uid": "network-throughput-by-host",
  "version": 1,
  "panels": [
    {
      "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
      "description": "Drilldown of 'Total Network Throughput' - inbound dimension. One line per host (terms aggregation on host.name). Physical interfaces only (lo/veth/docker/br/virbr excluded).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false, "axisCenteredZero": false, "axisColorMode": "text",
            "axisLabel": "", "axisPlacement": "left", "axisWidth": 60,
            "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "linear", "lineWidth": 2,
            "pointSize": 5, "showPoints": "never", "spanNulls": false,
            "stacking": { "mode": "none", "group": "A" }
          },
          "mappings": [],
          "min": 0,
          "nullValueMode": "null",
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" },
        "maxDataPoints": 3000
      },
      "pluginVersion": "11.3.0",
      "targets": [
        {
          "alias": "{{term host.name}}",
          "bucketAggs": [
            { "id": "2", "type": "terms", "field": "host.name", "settings": { "min_doc_count": "1", "order": "desc", "orderBy": "_term", "size": "50" } },
            { "id": "3", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "$__interval", "min_doc_count": 0 } }
          ],
          "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
          "metrics": [{ "id": "1", "type": "sum", "field": "system.network.in.bytes_rate" }],
          "query": "_index:metrics-system.network-default* AND NOT system.network.name:lo AND NOT system.network.name:veth* AND NOT system.network.name:docker* AND NOT system.network.name:br-* AND NOT system.network.name:virbr* AND _exists_:system.network.in.bytes_rate",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Network In by Host",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
      "description": "Drilldown of 'Total Network Throughput' - outbound dimension. One line per host (terms aggregation on host.name). Physical interfaces only (lo/veth/docker/br/virbr excluded).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false, "axisCenteredZero": false, "axisColorMode": "text",
            "axisLabel": "", "axisPlacement": "left", "axisWidth": 60,
            "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "linear", "lineWidth": 2,
            "pointSize": 5, "showPoints": "never", "spanNulls": false,
            "stacking": { "mode": "none", "group": "A" }
          },
          "mappings": [],
          "min": 0,
          "nullValueMode": "null",
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" },
        "maxDataPoints": 3000
      },
      "pluginVersion": "11.3.0",
      "targets": [
        {
          "alias": "{{term host.name}}",
          "bucketAggs": [
            { "id": "2", "type": "terms", "field": "host.name", "settings": { "min_doc_count": "1", "order": "desc", "orderBy": "_term", "size": "50" } },
            { "id": "3", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "$__interval", "min_doc_count": 0 } }
          ],
          "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
          "metrics": [{ "id": "1", "type": "sum", "field": "system.network.out.bytes_rate" }],
          "query": "_index:metrics-system.network-default* AND NOT system.network.name:lo AND NOT system.network.name:veth* AND NOT system.network.name:docker* AND NOT system.network.name:br-* AND NOT system.network.name:virbr* AND _exists_:system.network.out.bytes_rate",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Network Out by Host",
      "type": "timeseries"
    }
  ]
}
