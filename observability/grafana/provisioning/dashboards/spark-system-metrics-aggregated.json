                "interval": "$__interval"
              },
              "type": "date_histogram"
            }
          ],
          "datasource": {
            "type": "elasticsearch",
            "uid": "spark-elasticsearch"
          },
          "metrics": [
            {
              "field": "gpu.memory.used_bytes",
              "id": "1",
              "type": "avg",
              "hide": true
            },
            {
              "field": "gpu.memory.total_bytes",
              "id": "2",
              "type": "avg",
              "hide": true
            },
            {
              "id": "3",
              "type": "bucket_script",
              "pipelineAgg": "2",
              "settings": {
                "script": "params.used != null && params.total != null && params.total > 0 ? (params.used / params.total) * 100.0 : null"
              },
              "pipelineVariables": [
                { "name": "used", "pipelineAgg": "1" },
                { "name": "total", "pipelineAgg": "2" }
              ]
            }
          ],
          "query": "_index:metrics-gpu-default* AND _exists_:gpu.memory.used_bytes AND _exists_:gpu.memory.total_bytes",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
