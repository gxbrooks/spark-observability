          "metrics": [
            { "id": "1", "type": "sum", "field": "system.network.out.bytes_rate", "hide": true },
            {
              "id": "2",
              "type": "bucket_script",
              "pipelineAgg": "1",
              "settings": { "script": "params._value != null && params._value >= 0 ? params._value : null" },
              "pipelineVariables": [{ "name": "_value", "pipelineAgg": "1" }]
            }
