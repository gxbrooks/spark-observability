          "query": "_index:metrics-system.network-default* AND (host.name:(Lab1 OR Lab2 OR Lab3 OR Lab1.lan OR Lab2.lan OR Lab3.lan OR lab1 OR lab2 OR lab3 OR lab1.lan OR lab2.lan OR lab3.lan)) AND system.network.name:(enp* OR ens* OR eth0 OR eth1 OR wlp*) AND NOT system.network.name:lo AND _exists_:system.network.out.bytes_rate",
