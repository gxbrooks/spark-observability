    {
      "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
      "description": "Average CPU across cores (normalized 0–100%). Same axis and units as Spark System Metrics; legend differs. Filtered to Lab1–Lab3.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "left",
            "axisWidth": 50,
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.8 }
            ]
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": [] }, "tooltip": { "mode": "multi" } },
      "pluginVersion": "8.7.1",
      "targets": [
        {
          "alias": "{{term host.name}} CPU",
          "bucketAggs": [
            { "id": "1", "type": "terms", "field": "host.name", "settings": { "min_doc_count": "1", "order": "asc", "orderBy": "_key", "size": "10" } },
            { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "$__interval" } }
          ],
          "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
          "metrics": [{ "field": "system.cpu.total.norm.pct", "id": "1", "type": "avg" }],
          "query": "_index:metrics-system.cpu-default* AND (host.name:(Lab1 OR Lab2 OR Lab3 OR Lab1.lan OR Lab2.lan OR Lab3.lan OR lab1 OR lab2 OR lab3 OR lab1.lan OR lab2.lan OR lab3.lan))",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Host CPU utilization (% of capacity, per host)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "elasticsearch", "uid": "spark-elasticsearch" },
