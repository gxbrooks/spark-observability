          "metrics": [
            { "id": "1", "type": "sum", "field": "system.network.in.bytes_rate", "hide": true },
            {
              "id": "2",
              "type": "bucket_script",
              "pipelineAgg": "1",
              "settings": { "script": "params._value != null && params._value >= 0 ? params._value * -1 : null" },
              "pipelineVariables": [{ "name": "_value", "pipelineAgg": "1" }]
            }
          ],
          "query": "_index:metrics-system.network-default* AND (host.name:(Lab1 OR Lab2 OR Lab3 OR Lab1.lan OR Lab2.lan OR Lab3.lan OR lab1 OR lab2 OR lab3 OR lab1.lan OR lab2.lan OR lab3.lan)) AND system.network.name:(enp* OR ens* OR eth0 OR eth1 OR wlp*) AND NOT system.network.name:lo AND _exists_:system.network.in.bytes_rate",
          "refId": "A",
          "timeField": "@timestamp"
        },
        {
          "alias": "{{term host.name}} Out",
          "bucketAggs": [
            { "id": "2", "type": "terms", "field": "host.name", "settings": { "min_doc_count": "1", "order": "asc", "orderBy": "_key", "size": "10" } },
