          "query": "_index:metrics-gpu-default* AND (host.name.keyword:(Lab1 OR Lab2 OR Lab3 OR Lab1.lan OR Lab2.lan OR Lab3.lan OR lab1 OR lab2 OR lab3 OR lab1.lan OR lab2.lan OR lab3.lan))",
